{
  "compilerOptions": {
    "target": "ES2021",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "jsx": "preserve",
    "baseUrl": ".",
    "paths": {
      "@/*": ["frontend/src/*"]
    },
    "types": ["vite/client", "node"],
    "lib": ["ES2021", "DOM", "DOM.Iterable"]
  },
  "include": [
    "frontend/src/**/*.ts",
    "frontend/src/**/*.d.ts",
    "frontend/src/**/*.tsx",
    "frontend/src/**/*.vue",
    "vite.config.ts"
  ],
  "exclude": ["node_modules", "frontend/dist"]
}
