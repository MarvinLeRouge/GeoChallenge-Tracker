[run]
source = app
omit =
    app/models/*
    app/domain/models/*
    */tests/*
    */__init__.py
    */migrations/*
    app/main.py
    app/db/seed_data.py
    app/db/seed_indexes.py

[report]
exclude_lines =
    pragma: no cover
    def __repr__
    raise AssertionError
    raise NotImplementedError
    if __name__ == .__main__.:
    if TYPE_CHECKING:
    @abstractmethod
precision = 2

[html]
directory = htmlcov